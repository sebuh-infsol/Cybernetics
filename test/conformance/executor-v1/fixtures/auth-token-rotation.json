{
  "_fixture": "auth-token-rotation",
  "_description": "Auth hardening: first registration from a non-loopback address triggers token rotation. aiwg serve issues a rotated token and emits a warning. The executor must use the new token on subsequent calls. Also validates that a loopback re-register returns the original token (identity persistence). Schema refs: $defs/register_payload, $defs/register_response.",
  "_schema_refs": [
    "#/$defs/register_payload",
    "#/$defs/register_response"
  ],
  "phase_1_initial_loopback_register": {
    "_description": "Executor first registers from loopback (127.0.0.1). Normal happy path.",
    "request": {
      "method": "POST",
      "path": "/api/v1/executors/register",
      "_remote_addr": "127.0.0.1",
      "body": {
        "_validates_as": "#/$defs/register_payload",
        "executor_id": "c3d4e5f6-a7b8-9012-cdef-345678901234",
        "name": "local-executor-v1",
        "version": "1.0.0",
        "spec_version": "1.0.0",
        "transport_endpoints": {
          "rest": "http://127.0.0.1:8200",
          "ws": "ws://127.0.0.1:8201"
        },
        "capabilities": [
          "isolation:none",
          "runtime:claude-code",
          "platform:linux/x64"
        ]
      }
    },
    "response": {
      "status": 201,
      "body": {
        "_validates_as": "#/$defs/register_response",
        "executor_id": "c3d4e5f6-a7b8-9012-cdef-345678901234",
        "token": "exec_tk_INITIAL_LoopbackToken1234",
        "registered_at": "2026-05-08T22:00:00.000Z"
      }
    }
  },
  "phase_2_non_loopback_register": {
    "_description": "Operator subsequently binds aiwg serve to 0.0.0.0 for LAN access. The executor re-registers from its LAN IP. aiwg serve detects the non-loopback origin, rotates the token, and warns.",
    "request": {
      "method": "POST",
      "path": "/api/v1/executors/register",
      "_remote_addr": "192.168.1.42",
      "_note": "Same executor_id, different source address — triggers token rotation per auth spec.",
      "body": {
        "_validates_as": "#/$defs/register_payload",
        "executor_id": "c3d4e5f6-a7b8-9012-cdef-345678901234",
        "name": "local-executor-v1",
        "version": "1.0.0",
        "spec_version": "1.0.0",
        "transport_endpoints": {
          "rest": "http://192.168.1.42:8200",
          "ws": "ws://192.168.1.42:8201"
        },
        "capabilities": [
          "isolation:none",
          "runtime:claude-code",
          "platform:linux/x64"
        ]
      }
    },
    "response": {
      "status": 201,
      "body": {
        "_validates_as": "#/$defs/register_response",
        "_note": "token MUST differ from the loopback token — rotation occurred.",
        "executor_id": "c3d4e5f6-a7b8-9012-cdef-345678901234",
        "token": "exec_tk_ROTATED_NonLoopback5678",
        "registered_at": "2026-05-08T22:15:00.000Z"
      },
      "_headers": {
        "X-AIWG-Warning": "Token rotated: first non-loopback registration for executor c3d4e5f6-a7b8-9012-cdef-345678901234. Update stored token."
      }
    }
  },
  "phase_3_old_token_rejected": {
    "_description": "The old loopback token must be rejected after rotation.",
    "request": {
      "method": "GET",
      "path": "/api/v1/executors",
      "headers": {
        "Authorization": "Bearer exec_tk_INITIAL_LoopbackToken1234"
      }
    },
    "response": {
      "status": 401,
      "body": {
        "error": "token_invalid",
        "detail": "The bearer token has been rotated. Re-register to obtain a new token."
      }
    }
  },
  "phase_4_new_token_accepted": {
    "_description": "The rotated token must work for subsequent calls.",
    "request": {
      "method": "GET",
      "path": "/api/v1/executors",
      "headers": {
        "Authorization": "Bearer exec_tk_ROTATED_NonLoopback5678"
      }
    },
    "response": {
      "status": 200,
      "body": {
        "_validates_as": "#/$defs/executors_list_response",
        "executors": [
          {
            "_validates_as": "#/$defs/executor_status",
            "executor_id": "c3d4e5f6-a7b8-9012-cdef-345678901234",
            "name": "local-executor-v1",
            "version": "1.0.0",
            "spec_version": "1.0.0",
            "transport_endpoints": {
              "rest": "http://192.168.1.42:8200",
              "ws": "ws://192.168.1.42:8201"
            },
            "capabilities": [
              "isolation:none",
              "runtime:claude-code",
              "platform:linux/x64"
            ],
            "connected": true,
            "active_mission_count": 0,
            "registered_at": "2026-05-08T22:15:00.000Z"
          }
        ]
      }
    }
  },
  "assertions": [
    "phase_1 response.body.token != phase_2 response.body.token (rotation occurred)",
    "phase_3 response.status == 401 (old token rejected)",
    "phase_4 response.status == 200 (new token accepted)"
  ]
}
