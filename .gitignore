local-notes/
.local/
personal-notes.md
TODO.local.md

# Provider deployment directories (generated by `aiwg use`, local only)
.agents/
.claude/
.codex/
.cursor/
.factory/
.github/*
!.github/workflows/
.opencode/
.warp/
.windsurf/

# AIWG project artifacts — tracked in git (except ephemeral content)
# .aiwg/ is NOT gitignored — it contains SDLC artifacts (ADRs, use cases, etc.)
# The following subdirectories are ephemeral and excluded:
.aiwg/working/
.aiwg/.index/
.aiwg/.storage-cache/
.aiwg/ralph/archive/
.aiwg/ralph-external/loops/

# Agent temporary files
_agent-temp/
docs/references/pdfs/*.pdf

# Test temp directories (created by file watcher tests)
test-temp-watch-*/
test/**/.tmp-*/

# AIWG — ignore only high-churn runtime subdirs, NOT .aiwg/ itself
.aiwg/ralph/
.aiwg/ralph-external/
