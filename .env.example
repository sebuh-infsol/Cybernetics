# DO NOT put real secrets here. Use GCP Secret Manager.
# This file is for local development only.

# Required
BROKER_API_KEY=dev-local-key
GEMINI_API_KEY=your-gemini-key
POSTGRES_DSN=postgresql+asyncpg://user:pass@localhost/sentinel

# Cloud SQL / AlloyDB (production)
# POSTGRES_DSN=postgresql+asyncpg://user@/sentinel?host=/cloudsql/PROJECT:REGION:INSTANCE

# Optional adapters
DYNATRACE_BASE_URL=
DYNATRACE_API_TOKEN=
ELASTIC_CLOUD_ID=
ELASTIC_API_KEY=
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
ARIZE_API_KEY=
ARIZE_ENDPOINT=https://app.phoenix.arize.com
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
GITHUB_TOKEN=
STRIPE_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
VERCEL_TOKEN=
SUPABASE_URL=
SUPABASE_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
BROWSER_CDP_HOST=localhost
BROWSER_CDP_PORT=9222

# Slack
SLACK_BOT_TOKEN=xoxb-your-token

# Kubernetes
KUBECONFIG_CONTEXT=
KUBERNETES_NAMESPACE=default

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Notion
NOTION_TOKEN=

# Linear
LINEAR_API_KEY=

# GCP Secret Manager — set these in Cloud Run:
#   --set-secrets BROKER_API_KEY=projects/$PROJECT_ID/secrets/broker-api-key:latest
#   --set-secrets GEMINI_API_KEY=projects/$PROJECT_ID/secrets/gemini-api-key:latest
#   --set-secrets POSTGRES_DSN=projects/$PROJECT_ID/secrets/postgres-dsn:latest
