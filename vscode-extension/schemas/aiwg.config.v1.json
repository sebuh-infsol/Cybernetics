{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aiwg.io/schemas/aiwg.config.v1.json",
  "title": "AIWG Project Configuration",
  "description": "Configuration file for the AIWG AI coding assistant framework",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "AIWG config format version",
      "examples": ["1"]
    },
    "project": {
      "type": "string",
      "description": "Project name"
    },
    "installed": {
      "type": "object",
      "description": "Installed AIWG frameworks",
      "additionalProperties": {
        "$ref": "#/definitions/InstalledFramework"
      }
    },
    "providers": {
      "type": "array",
      "description": "Active AI provider targets",
      "items": {
        "type": "string",
        "enum": [
          "claude",
          "copilot",
          "cursor",
          "warp",
          "windsurf",
          "openclaw",
          "codex",
          "opencode",
          "factory",
          "hermes"
        ]
      }
    },
    "scripts": {
      "type": "object",
      "description": "Named scripts runnable via AIWG sidebar or CLI",
      "additionalProperties": {
        "type": "string"
      }
    },
    "settings": {
      "type": "object",
      "description": "Framework-specific settings",
      "additionalProperties": true
    },
    "remotes": {
      "type": "object",
      "description": "Repo origin topology — declares primary (CI/issues/PRs) and secondary remotes (#994)",
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "string",
          "description": "git remote name driving CI/PRs by default. Defaults to 'origin' when absent."
        },
        "issue_tracker": {
          "type": "string",
          "description": "Where issues live. Defaults to primary."
        },
        "ci": {
          "type": "string",
          "description": "Where CI runs. Defaults to primary."
        },
        "secondary": {
          "type": "array",
          "description": "Mirrors, fork bases, and publishing targets",
          "items": {
            "$ref": "#/definitions/SecondaryRemote"
          }
        }
      }
    },
    "delivery": {
      "type": "object",
      "description": "Repo control / delivery policy — how AIWG agents are expected to ship code (#995)",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["direct", "feature-branch", "pr-required"],
          "description": "How agents deliver code. direct = commit/push to default_branch; feature-branch = push branch, no PR; pr-required = branch + PR (default)"
        },
        "default_branch": {
          "type": "string",
          "description": "Default branch name. Defaults to 'main'."
        },
        "branch_naming": {
          "type": "object",
          "description": "Branch-naming conventions. {issue} and {slug} are interpolated by skills.",
          "additionalProperties": false,
          "properties": {
            "prefix_by_type": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "description": "Per commit-type branch prefix templates (feat, fix, docs, chore, refactor, test)"
            }
          }
        },
        "merge_style": {
          "type": "string",
          "enum": ["rebase-merge", "squash", "merge", "fast-forward-only"],
          "description": "Merge style. Defaults to 'rebase-merge'."
        },
        "delete_branch_on_merge": {
          "type": "boolean",
          "description": "Delete the feature branch after merge. Default true."
        },
        "require_ci_green": {
          "type": "boolean",
          "description": "Agent must wait for CI green before declaring done. Default true."
        },
        "require_signed_commits": {
          "type": "boolean",
          "description": "Default false."
        },
        "force_push_policy": {
          "type": "string",
          "enum": ["never", "own-branch-only", "allowed"],
          "description": "Force-push policy. Default 'never'."
        },
        "auto_close_issues": {
          "type": "boolean",
          "description": "Include 'Closes #N' in PR body. Default true."
        },
        "issue_comment_on_cycle": {
          "type": "boolean",
          "description": "Post AL CYCLE status comments to issue threads. Default true."
        }
      }
    }
  },
  "definitions": {
    "SecondaryRemote": {
      "type": "object",
      "description": "A non-primary git remote (mirror, upstream, publishing target)",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Must match a name from `git remote`"
        },
        "purpose": {
          "type": "string",
          "description": "Free-form tag (mirror | upstream | publish | replica)"
        },
        "push_on_release": {
          "type": "boolean",
          "description": "Hint to release workflows to push tags here on stable cuts"
        }
      }
    },
    "InstalledFramework": {
      "type": "object",
      "description": "Metadata for an installed AIWG framework",
      "properties": {
        "version": {
          "type": "string",
          "description": "Installed framework version (CalVer: YYYY.M.PATCH)"
        },
        "providers": {
          "type": "array",
          "description": "Providers this framework was deployed to",
          "items": {
            "type": "string"
          }
        },
        "installedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of installation"
        },
        "source": {
          "type": "string",
          "description": "Source registry or path"
        }
      },
      "additionalProperties": false
    }
  }
}
